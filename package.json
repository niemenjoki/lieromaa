{
  "name": "lieromaa",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prepare:site": "node lib/prebuild/index.mjs",
    "discounts:generate": "node lib/prebuild/generateDiscountCodes.mjs",
    "postinstall": "npm run prepare:site",
    "predev": "npm run format && npm run prepare:site",
    "prebuild": "npm test",
    "prelint": "npm run prepare:site",
    "pretest": "npm run prepare:site",
    "log:tags": "node lib/devHelpers/logAllTags.js",
    "dev": "next dev -H 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "node --import ./test/register.mjs --test ./test/discounts/*.test.mjs ./test/orders/*.test.mjs ./test/routes/*.test.mjs ./test/reviews/*.test.mjs",
    "verify": "npm run format:check && npm run lint && npm run build",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@fortawesome/free-brands-svg-icons": "^7.1.0",
    "@fortawesome/free-solid-svg-icons": "^7.1.0",
    "@fortawesome/react-fontawesome": "^3.1.0",
    "@vercel/speed-insights": "^1.2.0",
    "fuse.js": "^7.1.0",
    "next": "^15.5.7",
    "next-mdx-remote": "^6.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "swiper": "^12.0.3"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "eslint": "^9.37.0",
    "eslint-config-next": "^15.5.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.6.2",
    "sharp": "^0.34.3"
  },
  "license": "MIT",
  "engines": {
    "node": "22.x"
  }
}
